# Copy this to .env and fill in your values
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION_PATH=./state/telegram_session

NOTION_API_KEY=ntn_your_integration_token_here
NOTION_DATABASE_ID=
NOTION_API_VERSION=

# Comma-separated Telegram channel usernames (without @)
TELEGRAM_CHANNELS=

# Sync interval in seconds (300 = 5 minutes)
SYNC_INTERVAL_SECONDS=300

# Paths
STATE_FILE=./state/sync_state.json
STATUS_FILE=./state/status.json
IMPORTED_FILE=./state/imported.json
LOG_DIR=./logs

# Retry settings
MAX_RETRIES=5
RETRY_BASE_DELAY=2.0
REQUEST_TIMEOUT=30

# Log rotation
LOG_MAX_BYTES=5242880
LOG_BACKUP_COUNT=5
